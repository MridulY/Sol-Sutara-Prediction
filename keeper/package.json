    "bullmq": "^5.7.0",
    "eventsource": "^2.0.2",
    "ioredis": "^5.4.1",
    "pino": "^9.2.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
