{
  "name": "@sutara/keeper",
  "version": "1.0.0",
  "private": true,
  "description": "Sutara protocol keeper — autonomous settlement service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
